# Database
DATABASE_URI=postgresql://postgres:password@localhost:5432/payload

# Payload Secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-key-min-32-characters

# Next.js
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Storage (optional - configure for S3, Cloudflare R2, etc.)
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=

# Email (optional - configure for SMTP, SendGrid, etc.)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=